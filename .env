# ================================
# NIDS Frontend — Environment Variables
# ================================

# Backend API URL
# Development (local):
VITE_API_URL=http://localhost:5000/api

# Production (uncomment and replace with your server IP/domain):
# VITE_API_URL=http://YOUR_SERVER_IP:5000/api

# ================================
# Mock Mode
# true  → use mock data (no backend needed)
# false → connect to real backend
# ================================
VITE_USE_MOCK=true